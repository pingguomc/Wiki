":{"position":[[18,5]]}}}],["compon",{"_index":8,"t":{"58":{"position":[[4,10]]}}}],["config",{"_index":1,"t":{"52":{"position":[[11,6]]}}}],["docusauru",{"_index":0,"t":{"52":{"position":[[0,10]]}}}],["github",{"_index":10,"t":{"60":{"position":[[1,6]]}}}],["homepagefeatur",{"_index":9,"t":{"58":{"position":[[15,16]]}}}],["index",{"_index":7,"t":{"56":{"position":[[10,5]]},"58":{"position":[[32,5]]}}}],["js",{"_index":2,"t":{"52":{"position":[[18,2]]},"56":{"position":[[16,2]]},"58":{"position":[[38,2]]}}}],["json",{"_index":4,"t":{"54":{"position":[[8,4]]}}}],["packag",{"_index":3,"t":{"54":{"position":[[0,7]]}}}],["page",{"_index":6,"t":{"56":{"position":[[4,5]]}}}],["src",{"_index":5,"t":{"56":{"position":[[0,3]]},"58":{"position":[[0,3]]}}}],["workflow",{"_index":11,"t":{"60":{"position":[[8,9]]}}}],["yml",{"_index":13,"t":{"60":{"position":[[24,3]]}}}]],"pipeline":["stemmer"]}},{"documents":[{"i":39,"t":"跟着模板走, 文档不用愁","s":"Docusaurus 插件文档模板","u":"/Wiki/en/intro","h":"","p":38},{"i":41,"t":"点击本仓库右上角的Fork按钮 取消勾选Copy the main branch only选项 随便改一个Repository name, 比如你可以改成XXX-Wiki(后文的教学中将默认你的仓库名称是XXX-Wiki) 点击Create fork","s":"Fork仓库","u":"/Wiki/en/Fork仓库","h":"","p":40},{"i":43,"t":"我不管你用什么方法, 你给我把东西下载下来","s":"下载仓库","u":"/Wiki/en/下载仓库","h":"","p":42},{"i":45,"t":"进入nodejs官网 俩绿油油的大按钮, 随便点一个下载 得到nodejs安装包 启动 无脑Next, 然后Install 点个Finish, 结束","s":"下载安装nodejs","u":"/Wiki/en/下载安装nodejs","h":"","p":44},{"i":47,"t":"进入根目录 windows左下角放大镜, 搜索命令提示符 管理员身份运行 点击查看根目录 查看路径 输入盘符ID:切换盘符 输入cd 路径切换目录 输入npm ci下载依赖","s":"下载依赖","u":"/Wiki/en/下载依赖","h":"","p":46},{"i":49,"t":".md文件全塞在docs文件夹里, 每个.md文件内部最上方有一个 --- sidebar_position: 1 --- 后面那个数字是当前文件在侧边栏的显示优先级, 1在2上面 如果需要多级标题, 就新建一个文件夹, 文件夹里塞一个_category_.json文件 { \"position\": 999, \"link\": { \"type\": \"generated-index\" } } 这里的position和.md文件中的sidebar_position起一样的作用, 用于表示它在侧边栏显示的顺序 言尽于此, 我已经将所有麻烦内容的解决方法告知于你, 剩下的自己去官网学吧 中文官网 中英文官网","s":"开冲","u":"/Wiki/en/开冲","h":"","p":48},{"i":51,"t":"我将缩减各种不必要内容, 仅展示需要更改的部分","s":"更改各种路径","u":"/Wiki/en/更改各种路径","h":"","p":50},{"i":53,"t":"const config = { // 标题 title: 'XXX', // 标题底下的一行介绍 tagline: '测试Wiki', // 你的github链接 url: 'https://neige7.github.io', // 你的github项目名称 baseUrl: '/XXX-Wiki/', // 你的github名称 organizationName: 'neige7', // 你的github项目名称 projectName: 'XXX-Wiki', presets: [ [ ({ docs: { sidebarPath: require.resolve('./sidebars.js'), routeBasePath: '/', editUrl: // 主分支链接 'https://github.com/Neige7/XXX-Wiki/blob/main' }, }), ], ], themeConfig: ({ navbar: { // 上边栏标题 title: 'XXX', items: [ { // github链接 href: 'https://github.com/Neige7/XXX', label: 'GitHub', position: 'right', }, ], }, // 底部链接 footer: { style: 'dark', links: [ { title: '交流', items: [ { label: 'QQ群', // 加群链接 href: 'https://www.baidu.com', }, ], }, { title: '插件发布', items: [ { label: 'GitHub', // github链接 href: 'https://github.com/Neige7/XXX', }, ], }, ], // 底部版权信息 copyright: `Copyright © ${new Date().getFullYear()} Neige, All Rights Reserved.`, }, }), }; module.exports = config;","s":"docusaurus.config.js","u":"/Wiki/en/更改各种路径","h":"#docusaurusconfigjs","p":50},{"i":55,"t":"{ // 名称 \"name\": \"xxx-wiki\", // 版本 \"version\": \"0.0.0\", }","s":"package.json","u":"/Wiki/en/更改各种路径","h":"#packagejson","p":50},{"i":57,"t":"// 你只需要改底下那个\"点击查看文档\" function HomepageHeader() { const {siteConfig} = useDocusaurusContext(); return ( <header className={clsx('hero hero--primary', styles.heroBanner)}> <div className=\"container\"> <h1 className=\"hero__title\">{siteConfig.title}</h1> <p className=\"hero__subtitle\">{siteConfig.tagline}</p> <div className={styles.buttons}> <Link className=\"button button--secondary button--lg\" to=\"/intro\"> 点击查看文档 </Link> </div> </div> </header> ); }","s":"src\\pages\\index.js","u":"/Wiki/en/更改各种路径","h":"#srcpagesindexjs","p":50},{"i":59,"t":"const FeatureList = [ { title: '简单易用', Svg: require('@site/static/img/undraw_docusaurus_mountain.svg').default, description: ( <> 就这点配置有啥难的. </> ), }, { title: '文档详细', Svg: require('@site/static/img/undraw_docusaurus_tree.svg').default, description: ( <> 看完文档学不会怎么用说明你是个傻逼. </> ), }, { title: '功能强大', Svg: require('@site/static/img/undraw_docusaurus_react.svg').default, description: ( <> 多说无益, 用用就知道了. </> ), }, ];","s":"src\\components\\HomepageFeatures\\index.js","u":"/Wiki/en/更改各种路径","h":"#srccomponentshomepagefeaturesindexjs","p":50},{"i":61,"t":"jobs: # 自动生成PDF pdf: # 生成PDF - name: Build PDF # neige7换成你的id, XXX-Wiki改成项目名称 run: sudo docker run --rm -v ${{ github.workspace }}/pdf:/app/pdf iseason/docusaurus-to-pdf -u https://neige7.github.io/XXX-Wiki/intro --output pdf/XXX-Wiki.pdf -u https://neige7.github.io/XXX-Wiki/en/intro --output pdf/XXX-Wiki-English.pdf # Release release: # 向release上传XXX-Wiki.pdf - name: Upload PDF file to Release with: # XXX-Wiki改成项目名称 asset_path: XXX-Wiki.pdf asset_name: XXX-Wiki.pdf","s":".github\\workflows\\build.yml","u":"/Wiki/en/更改各种路径","h":"#githubworkflowsbuildyml","p":50},{"i":63,"t":"1233211234567","s":"测试","u":"/Wiki/en/折叠示例2/测试","h":"","p":62},{"i":65,"t":"为师全帮你写好了, 你每次往上面提交完东西, 他就会自动更新网页, 生成pdf并发布","s":"自动生成pdf文件","u":"/Wiki/en/自动生成pdf文件","h":"","p":64},{"i":68,"t":"回到XXX-Wiki仓库页面 点击右上角的Settings按钮 点击左侧的Actions按钮 点击General按钮 翻到最下方的Workflow permissions部分 勾选Read and write permissions 勾选Allow GitHub Actions to create and approve pull requests 点击Save按钮","s":"设置Action权限","u":"/Wiki/en/设置Action权限","h":"","p":67},{"i":70,"t":"点击右上角你的头像 点击下方的Settings按钮 点击左下方的Developer settings按钮 点击左侧的Personal access tokens按钮 点击Tokens (classic)按钮 点击右上方的Generate new token按钮 点击Generate new token (classic)按钮 Note里填用途, 用于提醒你这是干什么的, 你可以直接填项目名称, 比如XXX-Wiki 将其设置为永不过期 勾选repo下的所有选项 点击最下方的Generate token按钮 复制生成的token(关闭页面后你就再也无法查看它了) 回到XXX-Wiki仓库页面 点击右上角的Settings按钮 点击左下方的Secrets and variables按钮 点击Actions按钮 点击右上角绿色的New repository secret按钮 Name填写ACCESS_TOKEN, Secret填写你刚才复制的东西 一定要填写 ACCESS_TOKEN 因为 build.yml里写的就是这个名 点击下方绿色的Add secret按钮","s":"设置ACCESS_TOKEN","u":"/Wiki/en/设置ACCESS_TOKEN","h":"","p":69},{"i":72,"t":"在gitlab那边导入这个仓库,或者你把这个仓库下载下来,传gitlab上 .gitlab-ci.yml 驿站帮你写好了awa 然后把 docusaurus.config.js 里的东西改